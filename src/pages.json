{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "kai",
        "enablePullDownRefresh": true,
        "onReachBottomDistance": 50,
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/mine/login/login",
      "style": {
        "navigationBarTitleText": "",
        "navigationStyle": "custom",
        "disableScroll": true
      }
    }
  ],
  "subPackages": [
    {
      "root": "subPackages/user",
      "name": "user",
      "pages": [
        {
          "path": "setting/setting",
          "style": {
            "navigationBarTitleText": "设置"
          }
        }
      ]
    },
    {
      "root": "subPackages/tools",
      "name": "tools",
      "pages": [

        {
          "path": "family-tree/index",
          "style": {
            "navigationBarTitleText": "族谱",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "family-tree/demo",
          "style": {
            "navigationBarTitleText": "族谱",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "oss-upload/index",
          "style": {
            "navigationBarTitleText": "文件上传",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "oss-upload/fileList",
          "style": {
            "navigationBarTitleText": "我的文件列表",
            "enablePullDownRefresh": true,
            "onReachBottomDistance": 50,
            "navigationStyle": "custom"
          }
        },
        {
          "path": "image-compress/index",
          "style": {
            "navigationBarTitleText": "图片压缩",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "qr-generator/index",
          "style": {
            "navigationBarTitleText": "二维码生成器",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "qr-parser/index",
          "style": {
            "navigationBarTitleText": "二维码解析",
            "navigationStyle": "custom"
          }
        }
      ]
    },
    {
      "root": "subPackages/services",
      "name": "services",
      "pages": [
        {
          "path": "recipe/index",
          "style": {
            "navigationBarTitleText": "食谱大全",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "recipe/detail",
          "style": {
            "navigationBarTitleText": "食谱详情",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "memo/list",
          "style": {
            "navigationBarTitleText": "我的备忘录",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "memo/editor",
          "style": {
            "navigationBarTitleText": "编辑备忘录",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "memo/detail",
          "style": {
            "navigationBarTitleText": "备忘录详情",
            "navigationStyle": "custom"
          }
        }
      ]
    },
    {
      "root": "subPackages/common",
      "name": "common",
      "pages": [
        {
          "path": "middle/index",
          "style": {
            "navigationBarTitleText": "E签"
          }
        },
        {
          "path": "middle/pay",
          "style": {
            "navigationBarTitleText": "支付"
          }
        },
        {
          "path": "middle/app",
          "style": {
            "navigationBarTitleText": "港生活APP"
          }
        },
        {
          "path": "webview/webview"
        },
        {
          "path": "webview/h5"
        }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "kai",
    "navigationBarBackgroundColor": "#fff",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#121A26",
    "selectedColor": "#121A26",
    // #ifdef MP-WEIXIN
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/image/index.png",
        "selectedIconPath": "static/image/index_on.png",
        "text": "首頁"
      },
      {
        "pagePath": "pages/mine/mine",
        "iconPath": "static/image/mine.png",
        "selectedIconPath": "static/image/mine_on.png",
        "text": "我的"
      }
    ]
    // #endif
  }
}